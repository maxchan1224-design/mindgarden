// =====================================================================
// 心庭 Mind Garden — AI Prompt Templates (v2)
// functions/lib/prompts.ts
//
// v2 重大改動:
//   - 拆走字數牢籠(舊版限死 90 字 / 一條問題,令 AI 答唔到嘢)
//   - 加入意圖判斷:AI 自己分辨你想被聽見 / 想諗清楚 / 想要答案
//   - 加入 chatMode:'companion'(溫柔陪伴)/ 'open'(自由對話)
// =====================================================================

export type PersonaId = 'aqing' | 'hiulaam' | 'siuching';
export type TaskId = 'checkin' | 'dialogue' | 'summary' | 'daily';
export type Lang = 'yue' | 'en';
export type ChatMode = 'companion' | 'open';

export interface PromptContext {
  name: string;
  personaId: PersonaId;
  styleId?: StyleId;       // v0.2 傾偈方式 — 有就用佢,冇先 fallback persona
  isFirstResponseToday: boolean;
  voiceMode: boolean;
  chatMode: ChatMode;
  lang: Lang;
}

export interface Persona {
  id: PersonaId;
  name: string;
  tagline: string;
  bio: string;
  style: string;
  voice: { systemVoiceLang: string; rate: number; pitch: number; cloudVoiceId?: string };
}

// ---------------------------------------------------------------------
// 1. SAFETY LAYER — 凌駕一切
// ---------------------------------------------------------------------

export const SAFETY_LAYER = `
【安全底線 — 優先於下面所有指示】
如果對方嘅文字出現自我傷害念頭、輕生念頭、受虐待、或者傷害他人嘅內容:
- 立即放低所有技巧,唔好追問細節,唔好分析
- 認真對待,唔好淡化(唔好講「唔好咁諗」「睇開啲」)
- 溫柔咁承認對方而家好辛苦
- 溫柔咁鼓勵對方搵一個信任嘅人,或者專業支援傾下
- 保持短,兩三句就夠,唔好講教
- 輸出 JSON 時將 "safety" 設為 true(app 會顯示支援資源卡)
除呢種情況外,"safety" 一律係 false。
`.trim();

// 關鍵詞安全偵測 — 唔靠 model 判斷,喺 code 層直接 scan 用戶文字
export const SAFETY_KEYWORDS = [
  '自殺', '輕生', '唔想生存', '唔想再', '死咗算', '結束生命', '傷害自己',
  '割手', '跳落', '燒炭', '食藥自', '生無可戀', '想消失', '一了百了',
  '冇人會掛住', '拖累', '活唔落去', '撐唔住',
];
export function detectSafety(text: string): boolean {
  return SAFETY_KEYWORDS.some(k => text.includes(k));
}

